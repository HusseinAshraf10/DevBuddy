{
  "manifest_version": 3,
  "name": "DevBuddy CS50",
  "version": "1.0.0",
  "description": "A tiny extension that explains basic programming terms.",
  "permissions": ["storage"],
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dictionary.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
